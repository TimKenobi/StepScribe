# ============================================================
# StepScribe - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ---------- AI Provider Configuration ----------
# Choose your AI provider: "openai", "anthropic", "grok", "ollama", or "custom"
AI_PROVIDER=openai

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Grok / xAI (https://console.x.ai/)
GROK_API_KEY=
GROK_MODEL=grok-3
GROK_BASE_URL=https://api.x.ai/v1

# Ollama - local models (https://ollama.ai)
# Make sure Ollama is running: ollama serve
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3

# Custom / OpenAI-compatible endpoint (e.g., LM Studio, vLLM, text-generation-webui)
CUSTOM_AI_BASE_URL=
CUSTOM_AI_API_KEY=
CUSTOM_AI_MODEL=

# ---------- Application Settings ----------
APP_NAME=StepScribe
APP_SECRET_KEY=change-me-to-a-random-secret-string
APP_ENV=development
APP_DEBUG=false

# ---------- Docker Ports ----------
# Change these if you have port conflicts with other containers
BACKEND_PORT=8100
FRONTEND_PORT=3100

# ---------- Database ----------
# SQLite database will be stored in the persistent volume
DATABASE_URL=sqlite+aiosqlite:///data/stepscribe.db

# ---------- Data Persistence ----------
# These paths are inside the container; mapped to local folders via docker-compose
DATA_DIR=/app/data
EXPORT_DIR=/app/data/exports
UPLOAD_DIR=/app/data/uploads

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=http://localhost:8100
NEXT_PUBLIC_APP_NAME=StepScribe

# ---------- Voice-to-Text ----------
# Uses browser Web Speech API by default (no key needed)
# Optional: Whisper API for server-side transcription
WHISPER_API_KEY=
WHISPER_MODEL=whisper-1

# ---------- Export / Journal Book ----------
# PDF generation settings
JOURNAL_BOOK_TITLE=My Recovery Journal
JOURNAL_BOOK_AUTHOR=

# ---------- Group Journaling ----------
# Enable group features (requires user auth)
ENABLE_GROUPS=true
GROUP_INVITE_EXPIRY_HOURS=48
